import java.util.Scanner;
public class TriangleArea {
    public static void main(String[] args) {
        Scanner input = new Scanner(System.in);
        System.out.print("Enter the base of the triangle (cm): ");
        double base = input.nextDouble();
        System.out.print("Enter the height of the triangle (cm): ");
        double height = input.nextDouble();
        double areaCm2 = 0.5 * base * height;
        double sqInchConversion = 2.54 * 2.54;
        double areaIn2 = areaCm2 / sqInchConversion;
        System.out.println("The Area of the triangle in sq in is " + areaIn2 + 
                           " and sq cm is " + areaCm2);
        input.close();
    }
}
